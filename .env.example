# --- Client (Vite) — safe to expose in the browser
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# --- Vercel serverless (/api/booking) — never expose to the client
# Same project URL as above (no VITE_ prefix is fine on Vercel)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret

# Resend (https://resend.com) — confirmation to guest + copy to you
RESEND_API_KEY=re_xxxx
# Optional; default is Resend onboarding sender (restricted). Use your verified domain in production.
RESEND_FROM_EMAIL=Exploration <bookings@yourdomain.com>
# Where you receive new booking alerts (concierge inbox)
NOTIFICATION_EMAIL=you@example.com
